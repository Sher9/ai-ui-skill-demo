/* 马卡龙 / 温暖治愈 (preset: macaron, --platform wechat)
   扁平 rpx token 块（来自 generate-tokens.mjs --preset macaron）。真实项目用：
     node scripts/generate-tokens.mjs --preset macaron --platform wechat --out wxss,json --dir <项目styles>
   再在 app.wxss 顶部 @import "styles/tokens.wxss"; 并去掉本页内联 token。 */
page {
  --color-bg: #faf8f5;
  --color-surface: #ffffff;
  --color-surface-2: #f6f3ee;
  --color-border: #f0ece5;
  --color-text: #554630;
  --color-text-2: #78664a;
  --color-primary: #f9a8d4;
  --color-primary-fg: #0a0a0b;
  --color-accent-2: #a7f3d0;
  --color-accent-3: #fcd34d;
  --color-accent-4: #c4b5fd;
  --color-accent-5: #fca5a5;
  --font-sans: "PingFang SC", "Helvetica Neue", "Microsoft YaHei", system-ui, sans-serif;
  --space-1: 8rpx; --space-2: 16rpx; --space-3: 24rpx; --space-4: 32rpx;
  --space-5: 40rpx; --space-6: 48rpx; --space-8: 64rpx;
  --radius-md: 16rpx; --radius-lg: 24rpx; --radius-xl: 32rpx; --radius-full: 19998rpx;
  --shadow-md: 0 8rpx 12rpx -2rpx rgba(57, 34, 47, 0.07), 0 4rpx 8rpx -4rpx rgba(57, 34, 47, 0.05);
  --shadow-lg: 0 20rpx 30rpx -6rpx rgba(57, 34, 47, 0.08), 0 8rpx 12rpx -8rpx rgba(57, 34, 47, 0.05);
  --safe-bottom: env(safe-area-inset-bottom);
  background: var(--color-bg);
  color: var(--color-text);
  font-family: var(--font-sans);
  font-size: 32rpx;
}

/* 顶部状态栏占位（微信胶囊右侧安全区） */
.nav { padding: calc(env(safe-area-inset-top) + 24rpx) var(--space-5) 24rpx; }
.nav .title { font-size: 44rpx; font-weight: 700; letter-spacing: -0.02em; }
.nav .sub { font-size: 26rpx; color: var(--color-text-2); margin-top: 8rpx; }

/* 粉彩心情卡：多强调色做底，主按钮仍用 primary */
.moods { display: flex; gap: var(--space-3); padding: var(--space-2) var(--space-5) var(--space-5); }
.mood { flex: 1; border-radius: var(--radius-lg); padding: var(--space-4); min-height: 150rpx; display: flex; flex-direction: column; justify-content: space-between; box-shadow: var(--shadow-md); }
.mood .emo { font-size: 48rpx; }
.mood .lb { font-size: 26rpx; color: var(--color-text-2); }
.mood.c2 { background: var(--color-accent-2); }
.mood.c3 { background: var(--color-accent-3); }
.mood.c4 { background: var(--color-accent-4); }
.mood.c5 { background: var(--color-accent-5); }
.mood.p { background: var(--color-primary); }

/* 列表卡 */
.list { padding: 0 var(--space-5); }
.card { background: var(--color-surface); border-radius: var(--radius-xl); padding: var(--space-5); margin-bottom: var(--space-4); box-shadow: var(--shadow-md); }
.card .hd { display: flex; align-items: center; gap: var(--space-3); }
.avatar { width: 72rpx; height: 72rpx; border-radius: var(--radius-full); background: var(--color-primary); display: flex; align-items: center; justify-content: center; font-size: 36rpx; }
.card .name { font-weight: 600; }
.card .meta { font-size: 24rpx; color: var(--color-text-2); }
.card .body { font-size: 28rpx; color: var(--color-text-2); margin-top: var(--space-3); line-height: 1.6; }
/* 粉彩标签 chip */
.chip { display: inline-block; font-size: 22rpx; padding: 4rpx 16rpx; border-radius: var(--radius-full); margin-right: 12rpx; margin-top: var(--space-3); }
.chip.c2 { background: var(--color-accent-2); color: #0a0a0b; }
.chip.c3 { background: var(--color-accent-3); color: #0a0a0b; }
.chip.c4 { background: var(--color-accent-4); color: #0a0a0b; }

/* 浮动按钮（触控目标 ≥88rpx） */
.fab { position: fixed; right: var(--space-6); bottom: calc(var(--safe-bottom) + 140rpx); width: 104rpx; height: 104rpx; border-radius: var(--radius-full); background: var(--color-primary); color: var(--color-primary-fg); display: flex; align-items: center; justify-content: center; font-size: 52rpx; box-shadow: var(--shadow-lg); }
.fab--hover { transform: scale(0.94); opacity: 0.9; }

/* 底部 Tab：含安全区 */
.tabbar { position: fixed; left: 0; right: 0; bottom: 0; display: flex; background: var(--color-surface); border-top: 1rpx solid var(--color-border); padding-bottom: var(--safe-bottom); }
.tab { flex: 1; height: 104rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6rpx; font-size: 22rpx; color: var(--color-text-2); }
.tab .ic { font-size: 40rpx; }
.tab.on { color: var(--color-text); font-weight: 600; }
.tab--hover { background: var(--color-surface-2); }
